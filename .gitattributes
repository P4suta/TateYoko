# Normalize line endings: LF in the repository, native on checkout (CRLF on
# Windows, matching .editorconfig). Explicit binaries are never normalized.
* text=auto eol=lf

# The justfile recipes run under bash; keep it LF even on Windows checkouts so
# stray CRLFs never reach the shell.
justfile text eol=lf

*.png binary
*.ico binary
*.pdf binary
*.zip binary
*.snk binary

*.bat text eol=crlf
*.cmd text eol=crlf
