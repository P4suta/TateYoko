<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TateYoko.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TateYoko.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Whole page is a drop target and, while idle, a click target (transparent background so hit testing works).  -->
    <Grid
        x:Name="RootDropTarget"
        AllowDrop="True"
        Background="Transparent"
        DragLeave="OnDragLeave"
        DragOver="OnDragOver"
        Drop="OnDrop"
        Tapped="OnRootTapped">

        <Grid Padding="32">
            <Grid
                MaxWidth="600"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">

                <!--  Idle: prompt (click anywhere or drop to open a PDF)  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ShowIf(ViewModel.IsIdle), Mode=OneWay}">
                    <FontIcon
                        FontSize="48"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xE896;" />
                    <TextBlock
                        x:Uid="IdleHeading"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                </StackPanel>

                <!--  Options  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Visibility="{x:Bind ShowIf(ViewModel.IsReady), Mode=OneWay}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <FontIcon
                            FontSize="20"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Glyph="&#xEA90;" />
                        <TextBlock
                            x:Name="InputFileText"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind ViewModel.InputFileName, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <controls:Segmented
                        x:Name="OpeningSegmented"
                        HorizontalAlignment="Center"
                        SelectedIndex="{x:Bind ViewModel.SelectedOpeningIndex, Mode=TwoWay}">
                        <controls:SegmentedItem x:Uid="OpeningStandard" />
                        <controls:SegmentedItem x:Uid="OpeningCover" />
                        <controls:SegmentedItem x:Uid="OpeningLeadingBlank" />
                    </controls:Segmented>

                    <Button
                        x:Name="ConvertButton"
                        x:Uid="ConvertButton"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.ConvertCommand}"
                        Style="{StaticResource AccentButtonStyle}" />
                    <HyperlinkButton
                        x:Name="PickAnotherButton"
                        x:Uid="PickAnotherButton"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.ResetCommand}" />
                </StackPanel>

                <!--  Converting  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Visibility="{x:Bind ShowIf(ViewModel.IsConverting), Mode=OneWay}">
                    <ProgressRing
                        Width="64"
                        Height="64"
                        IsIndeterminate="{x:Bind ViewModel.ProgressIndeterminate, Mode=OneWay}"
                        Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}" />
                </StackPanel>

                <!--  Done  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ShowIf(ViewModel.IsDone), Mode=OneWay}">
                    <FontIcon
                        FontSize="48"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        Glyph="&#xE73E;" />
                    <TextBlock
                        x:Name="DoneTitle"
                        x:Uid="DoneHeading"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.OutputFileName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <SplitButton
                        x:Name="OpenButton"
                        x:Uid="OpenButton"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.OpenOutputCommand}">
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem
                                    x:Name="ShowFolderButton"
                                    x:Uid="ShowFolderButton"
                                    Command="{x:Bind ViewModel.ShowInFolderCommand}" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <HyperlinkButton
                        x:Name="AnotherBookButton"
                        x:Uid="AnotherBookButton"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.ResetCommand}" />
                </StackPanel>

                <!--  Error  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ShowIf(ViewModel.IsError), Mode=OneWay}">
                    <FontIcon
                        FontSize="48"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Glyph="&#xE783;" />
                    <TextBlock
                        MaxWidth="440"
                        HorizontalAlignment="Center"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="ErrorBackButton"
                        x:Uid="ErrorBackButton"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.ResetCommand}" />
                </StackPanel>
            </Grid>
        </Grid>

        <!--  Full-window overlay shown while dragging (hit-test disabled so it does not block drag events).  -->
        <Border
            x:Name="DragOverlay"
            Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="3"
            IsHitTestVisible="False"
            Opacity="0.96"
            Visibility="Collapsed">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <FontIcon
                    FontSize="56"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                    Glyph="&#xE896;" />
                <TextBlock
                    x:Uid="DropOverlayText"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                    Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
